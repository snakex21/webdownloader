{
  "name": "webdownloader-desktop",
  "version": "1.0.0",
  "description": "Desktopowa aplikacja do pobierania stron internetowych wraz z zasobami",
  "author": "WebDownloader",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "web": "node server.js"
  },
  "dependencies": {
    "cheerio": "^1.0.0-rc.12",
    "express": "^4.22.1"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0"
  },
  "build": {
    "appId": "com.webdownloader.app",
    "productName": "WebDownloader",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "portable",
      "icon": "assets/icon.png"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "i18n.json"
    ]
  }
}
